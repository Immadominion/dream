HELIUS_API_KEY=your_helius_api_key

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_publishable_key
SUPABASE_REGISTER_DEVICE_FUNCTION=register-device
SUPABASE_HELIUS_WEBHOOK_FUNCTION=helius-webhook
SUPABASE_DISPATCH_NOTIFICATIONS_FUNCTION=dispatch-notifications
SUPABASE_RECORD_CLIENT_EVENT_FUNCTION=record-client-event

HELIUS_WEBHOOK_SECRET=your_helius_webhook_secret
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=notifications@trydream.fun

PRIVY_APP_ID=your_privy_app_id
PRIVY_CLIENT_ID=your_privy_client_id
PRIVY_REDIRECT_URI=dreamapp://auth-callback

# Phoenix Flight builder fee program — earn bps on every taker fill routed
# through the app. Register at https://flight.phoenix.trade
PHOENIX_BUILDER_AUTHORITY=your_builder_authority_pubkey
PHOENIX_BUILDER_PDA_INDEX=0
PHOENIX_BUILDER_SUBACCOUNT_INDEX=0

# Telegram Analytics Bot — developer-only push notifications
# 1. Create a bot via @BotFather on Telegram
# 2. Send /start to your bot, then visit:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    to find your numeric chat_id in the response
# Leave blank to disable analytics.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
